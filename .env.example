# AutoTube AI Video Generator - Environment Variables
# Copy this file to .env.local and fill in your API keys

# Server-side OpenRouter key (preferred). Used by /api/llm and quality-check.
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional BYOK fallback for local UI only (not baked into production builds).
# Prefer OPENROUTER_API_KEY on the server.
VITE_OPENROUTER_KEY=

# Production API gate — required when NODE_ENV=production.
# Clients send the same value as X-API-Key (Settings → AutoTube API Key).
AUTOTUBE_API_KEY=

# Optional: prefill the browser Settings field (dev only; do not bake into prod images)
VITE_AUTOTUBE_API_KEY=

# Optional: Serper API key for Google image search (server-side SERPER_API_KEY preferred)
# Get from: https://serper.dev/
SERPER_API_KEY=
VITE_SERPER_KEY=

# Optional: Firecrawl API key for web scraping (unused by current app path)
VITE_FIRECRAWL_KEY=

# Optional: xAI API key for Grok TTS narration (high quality)
# Get from: https://console.x.ai/
VITE_XAI_KEY=

# Optional: Cloudflare account ID and API token for MeloTTS (cheap fallback)
# Get from: https://dash.cloudflare.com/ → Workers AI → Use REST API
VITE_CF_ACCOUNT_ID=
VITE_CF_API_TOKEN=

# Optional: Self-hosted Kokoro TTS service URL (deploy tts-service/ on Railway)
# Leave empty to use local Kokoro Python or edge-tts fallback
KOKORO_SERVER_URL=

# Optional stock media (server-side preferred; UI BYOK still supported)
PEXELS_API_KEY=
PIXABAY_API_KEY=
VITE_PEXELS_KEY=
VITE_PIXABAY_KEY=
